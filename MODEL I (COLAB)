# ============================================================
# 1. CONFIGURATION & PATHS
# ============================================================
# Input / Output Data Paths
input_path   = "/content/FINAL_DATA.xlsx"
output_final = "/content/FINAL_PREPROCESSED_DATA.xlsx"

# Reports and Output Paths
summary_report_path   = "/content/YEARLY_SUMMARY_REPORTS.xlsx"
