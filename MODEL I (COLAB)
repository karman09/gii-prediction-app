best_pred_output_path = "/content/BEST_MODEL_PREDICTIONS_2025.xlsx"
hp_table_output_path  = "/content/GII_HYPERPARAMETER_TABLE.xlsx"

# Model & Scaler Save Paths
scaler_path       = "/content/SCALER.pkl"
