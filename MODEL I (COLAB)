df = pd.read_excel(input_path)

def find_country_col(df):
    for c in df.columns:
        if "country" in c.lower() or "economy" in c.lower():
            return c
    return df.select_dtypes(include=["object"]).columns[0]

country_col = find_country_col(df)
train_mask = df[year_col].isin(TRAIN_YEARS)
test_mask = df[year_col] == TEST_YEAR
protected_cols = [year_col, target_col, country_col]
numeric_cols = df.select_dtypes(include=[np.number]).columns.tolist()
process_cols = [c for c in numeric_cols if c not in protected_cols]

Xtr0 = df.loc[train_mask, process_cols].copy()
Xte0 = df.loc[test_mask, process_cols].copy()

Xtr3 = pd.DataFrame(index=Xtr0.index, columns=process_cols)
params_2024 = {}

for year in TRAIN_YEARS:
    idx_year = df[(df[year_col] == year) & train_mask].index
    X_year = Xtr0.loc[idx_year].copy()
    median_y = X_year.median()
    mad_y = (X_year - median_y).abs().median().replace(0, 1e-9)
    modz_y = 0.6745 * (X_year - median_y) / mad_y
    outlier_mask_y = (np.abs(modz_y) > 3.5)
    X_year_masked = X_year.mask(outlier_mask_y)
    for col in process_cols:
        X_year_masked.loc[outlier_mask_y[col], col] = median_y[col]
    scaler_y = StandardScaler()
    X_scaled_y = pd.DataFrame(scaler_y.fit_transform(X_year_masked), columns=process_cols, index=idx_year)
    imp_y = KNNImputer(n_neighbors=5)
    X_imp_scaled_y = pd.DataFrame(imp_y.fit_transform(X_scaled_y), columns=process_cols, index=idx_year)
    X_final_y = pd.DataFrame(scaler_y.inverse_transform(X_imp_scaled_y), columns=process_cols, index=idx_year)
    Xtr3.loc[idx_year] = X_final_y
    if year == 2024:
        params_2024 = {'median': median_y, 'mad': mad_y, 'scaler': scaler_y, 'imputer': imp_y}

modz_test = 0.6745 * (Xte0 - params_2024['median']) / params_2024['mad']
outlier_mask_test = (np.abs(modz_test) > 3.5)
Xte_masked = Xte0.mask(outlier_mask_test)
for col in process_cols:
    Xte_masked.loc[outlier_mask_test[col], col] = params_2024['median'][col]

Xte_scaled = pd.DataFrame(params_2024['scaler'].transform(Xte_masked), columns=process_cols, index=Xte0.index)
Xte_imp_scaled = pd.DataFrame(params_2024['imputer'].transform(Xte_scaled), columns=process_cols, index=Xte0.index)
Xte3 = pd.DataFrame(params_2024['scaler'].inverse_transform(Xte_imp_scaled), columns=process_cols, index=Xte0.index)

final_scaler = StandardScaler()
Xtr4 = pd.DataFrame(final_scaler.fit_transform(Xtr3), columns=Xtr3.columns, index=Xtr3.index)
Xte4 = pd.DataFrame(final_scaler.transform(Xte3), columns=Xte3.columns, index=Xte3.index)

