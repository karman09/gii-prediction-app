def sanitize_cols(cols): return [re.sub(r"[^A-Za-z0-9_]", "", c) for c in cols]

def build_lagged_block(df_block, features, lag):
    d = df_block.sort_values([country_col, year_col]).copy()
    lag_cols = []
    for f in features:
        c = f"{f}_lag{lag}"
        d[c] = d.groupby(country_col)[f].shift(lag)
        lag_cols.append(c)
    return d, lag_cols

def select_features_strict(train_df, candidates, lag):
    d_temp = train_df.sort_values([country_col, year_col]).copy()
    lagged_names = []
    for f in candidates:
        c = f"{f}_lag{lag}"
        d_temp[c] = d_temp.groupby(country_col)[f].shift(lag)
        lagged_names.append(c)
    work = d_temp.dropna(subset=lagged_names + [target_col])
    if len(work) < 15: return candidates
    X, y = work[lagged_names], work[target_col]
    try:
        lasso = LassoCV(cv=CV_VAL, random_state=42, n_jobs=-1).fit(X, y)
        cols = X.columns[np.abs(lasso.coef_) > 1e-5].tolist()
    except: cols = X.columns.tolist()
    if len(cols) == 0: cols = X.corrwith(y).abs().sort_values(ascending=False).head(10).index.tolist()
    return list(set([c.replace(f"_lag{lag}", "") for c in cols]))

final_results, hp_table_rows = [], []
global_best_rmse = float('inf')
global_best_predictions = pd.DataFrame()
global_best_model_obj, global_best_features, global_best_model_name = None, [], ""

for LAG in [1, 2]:
    print(f"Processing LAG: {LAG}")
    current_seed = RANDOM_STATE + (LAG * 11)
    for name, (model, params) in models_and_params.items():
        start_time = time.time()
        outer_r2, outer_rmse = [], []
        years = sorted(TRAIN_YEARS)
        for i in range(max(1, LAG), len(years)):
            tr_y, val_y = years[:i], years[i]
            sel_f = select_features_strict(df_ml[df_ml[year_col].isin(tr_y)], base_feature_cols, LAG)
            d, l_cols = build_lagged_block(df_ml[df_ml[year_col].isin(tr_y + [val_y])], sel_f, LAG)
            work = d.dropna(subset=l_cols + [target_col])
            tr_p, val_p = work[work[year_col].isin(tr_y)], work[work[year_col] == val_y]
            if tr_p.empty or val_p.empty: continue
            X_tr, y_tr, X_val, y_val = tr_p[l_cols], tr_p[target_col], val_p[l_cols], val_p[target_col]
            X_tr.columns = X_val.columns = sanitize_cols(l_cols)
            if len(X_tr) > CV_VAL * 2:
                search = RandomizedSearchCV(model.__class__(**model.get_params()), params, n_iter=N_ITER, cv=CV_VAL, scoring='neg_mean_squared_error', n_jobs=-1, random_state=current_seed).fit(X_tr, y_tr)
                best_m = search.best_estimator_
            else: best_m = model.__class__(**model.get_params()).fit(X_tr, y_tr)
            pred = np.clip(best_m.predict(X_val), 0, 100)
            outer_r2.append(r2_score(y_val, pred))
            outer_rmse.append(np.sqrt(mean_squared_error(y_val, pred)))

        f_sel = select_features_strict(df_ml[df_ml[year_col].isin(TRAIN_YEARS)], base_feature_cols, LAG)
        d_f, l_cols_f = build_lagged_block(df_ml[df_ml[year_col].isin(TRAIN_YEARS + [TEST_YEAR])], f_sel, LAG)
        w_f = d_f.dropna(subset=l_cols_f + [target_col])
        tr_f, te_f = w_f[w_f[year_col].isin(TRAIN_YEARS)], w_f[w_f[year_col] == TEST_YEAR]
        if not tr_f.empty and not te_f.empty:
            X_tr_f, y_tr_f, X_te_f, y_te_f = tr_f[l_cols_f], tr_f[target_col], te_f[l_cols_f], te_f[target_col]
            c_names = sanitize_cols(l_cols_f)
            X_tr_f.columns = X_te_f.columns = c_names
            search_f = RandomizedSearchCV(model.__class__(**model.get_params()), params, n_iter=N_ITER, cv=CV_VAL, scoring='neg_mean_squared_error', n_jobs=-1, random_state=current_seed).fit(X_tr_f, y_tr_f)
            best_f = search_f.best_estimator_
            y_pred_te, y_pred_tr = np.clip(best_f.predict(X_te_f), 0, 100), np.clip(best_f.predict(X_tr_f), 0, 100)
            cur_rmse = np.sqrt(mean_squared_error(y_te_f, y_pred_te))
            final_results.append({"Model": name, "Lag": LAG, "Num Features": len(l_cols_f), "Train R2": r2_score(y_tr_f, y_pred_tr), "Test R2": r2_score(y_te_f, y_pred_te), "RMSE": cur_rmse, "MAE": mean_absolute_error(y_te_f, y_pred_te), "MAPE %": mean_absolute_percentage_error(y_te_f, y_pred_te)*100, "CV R2 Mean": np.mean(outer_r2), "CV RMSE Mean": np.mean(outer_rmse), "Time (s)": round(time.time()-start_time, 2)})
            if cur_rmse < global_best_rmse:
                global_best_rmse, global_best_model_name, global_best_model_obj, global_best_features = cur_rmse, f"{name} (Lag {LAG})", best_f, c_names
                global_best_predictions = pd.DataFrame({"Country": te_f[country_col].values, "Year": TEST_YEAR, "Actual": y_te_f.values, "Predicted": y_pred_te})
            for p_n, p_v in search_f.best_params_.items():
                meta = param_meta.get(name, {}).get(p_n, {"desc": "-", "range": "-"})
                hp_table_rows.append({"Model Name": f"{name} (Lag {LAG})", "Hyperparameter": p_n, "Description": meta["desc"], "Range": meta["range"], "Optimal Value": p_v})

